<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0a0f1a">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}

  <script>document.documentElement.classList.replace('no-js', 'js');</script>
</head>

<body class="volt-body">
  <a class="skip-to-content" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

  {%- comment -%}
    NEON RAY ambient lighting layer — two blurred light-field orbs that drift
    with scroll velocity (driven by assets/neon-ray.js). Fixed behind all
    content; glass panels pick up the light as they pass over it.
  {%- endcomment -%}
  <div class="nr-ambient" aria-hidden="true">
    <span class="nr-orb nr-orb--amber" data-nr-orb data-nr-depth="0.35"></span>
    <span class="nr-orb nr-orb--teal" data-nr-orb data-nr-depth="0.6"></span>
  </div>

  {%- comment -%}
    VOLT FIELD — perspective-projected 3D particle lattice rendered on a
    2D canvas (assets/volt-field.js). Sits between the orbs and the content.
  {%- endcomment -%}
  <canvas id="VoltField" class="volt-field" aria-hidden="true"></canvas>

  {% section 'electrician-header' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'electrician-footer' %}

  <script src="{{ 'neon-ray.js' | asset_url }}" defer></script>
  <script src="{{ 'volt-field.js' | asset_url }}" defer></script>
</body>
</html>
