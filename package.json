{
  "name": "terra-stone-theme",
  "version": "1.0.0",
  "private": true,
  "description": "Premium immersive Shopify theme for a luxury landscaping company — WebGL scroll journey built with React Three Fiber, GSAP and Lenis.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-static-assets.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "theme:check": "shopify theme check --path theme",
    "theme:dev": "shopify theme dev --path theme",
    "theme:push": "shopify theme push --path theme",
    "assets:models": "node scripts/optimize-models.mjs",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "gsap": "^3.13.0",
    "lenis": "^1.3.11",
    "postprocessing": "^6.37.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.180.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@gltf-transform/cli": "^4.2.1",
    "@shopify/cli": "^3.85.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.180.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-glsl": "^1.5.1"
  },
  "engines": {
    "node": ">=20"
  }
}
