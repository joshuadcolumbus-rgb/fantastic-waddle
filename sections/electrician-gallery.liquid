{%- comment -%}
  ASYMMETRIC GRID BREAKOUT — project gallery.

  Editorial masonry on a 4-track grid with explicit span math per block:
    hero      → grid-column: span 2; grid-row: span 2;
    landscape → grid-column: span 2;
    portrait  → grid-row: span 2;
    square    → 1 × 1 baseline
  dense auto-flow staggers the tiles into an organic scroll rhythm.
{%- endcomment -%}

<section id="gallery" class="volt-section eh-gallery">
  <div class="volt-section__inner">
    <header class="eh-gallery__head" data-volt-reveal>
      <p class="volt-kicker">{{ section.settings.kicker | escape }}</p>
      <h2 class="volt-title">{{ section.settings.heading | escape }}</h2>
    </header>

    <div class="eh-gallery__grid">
      {%- for block in section.blocks -%}
        <figure
          class="eh-tile eh-tile--{{ block.settings.shape }}"
          data-volt-reveal
          style="--volt-stagger: {{ forloop.index0 | modulo: 4 }};"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'eh-tile__img', widths: '400, 800, 1200' }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'eh-tile__img eh-tile__img--placeholder' }}
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <figcaption class="eh-tile__caption">{{ block.settings.caption | escape }}</figcaption>
          {%- endif -%}
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% style %}
  .eh-gallery__head { max-width: 640px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }

  .eh-gallery__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 200px;
    grid-auto-flow: dense;
    gap: clamp(0.9rem, 2vw, 1.4rem);
  }

  .eh-tile {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: var(--volt-radius);
    border: 1px solid var(--volt-hairline);
    background: var(--volt-glass);
    box-shadow: 0 22px 50px -30px rgba(0, 0, 0, 0.8);
    transition: border-color 0.45s var(--volt-ease), box-shadow 0.45s var(--volt-ease);
  }

  .eh-tile:hover {
    border-color: rgba(245, 158, 11, 0.3);
    box-shadow:
      0 28px 60px -30px rgba(0, 0, 0, 0.85),
      0 0 24px -10px rgba(245, 158, 11, 0.25);
  }

  .eh-tile--hero      { grid-column: span 2; grid-row: span 2; }
  .eh-tile--landscape { grid-column: span 2; }
  .eh-tile--portrait  { grid-row: span 2; }

  @media (max-width: 979px) {
    .eh-gallery__grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 170px; }
  }

  @media (max-width: 639px) {
    .eh-gallery__grid { grid-template-columns: 1fr; grid-auto-rows: 220px; }
    .eh-tile--hero,
    .eh-tile--landscape,
    .eh-tile--portrait {
      grid-column: auto;
      grid-row: auto;
    }
  }

  .eh-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    transition: transform 0.8s var(--volt-ease);
  }

  .eh-tile:hover .eh-tile__img { transform: scale(1.08); }

  .eh-tile__img--placeholder {
    background: linear-gradient(160deg, #101a30, #0a0f1a);
    fill: rgba(148, 163, 184, 0.35);
  }

  .eh-tile__caption {
    position: absolute;
    inset: auto 0 0;
    padding: 2.2rem 1.1rem 0.95rem;
    background: linear-gradient(180deg, transparent, rgba(4, 7, 14, 0.85));
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--volt-ink);
  }
{% endstyle %}

{% schema %}
{
  "name": "Electrician gallery",
  "class": "section-electrician-gallery",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Field work"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recent installations"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Gallery tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "select",
          "id": "shape",
          "label": "Tile shape",
          "options": [
            { "value": "square", "label": "Square (1 × 1)" },
            { "value": "landscape", "label": "Landscape (2 × 1)" },
            { "value": "portrait", "label": "Portrait (1 × 2)" },
            { "value": "hero", "label": "Hero (2 × 2)" }
          ],
          "default": "square"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Electrician gallery",
      "blocks": [
        { "type": "tile", "settings": { "caption": "Commercial panel room", "shape": "hero" } },
        { "type": "tile", "settings": { "caption": "EV charger install", "shape": "square" } },
        { "type": "tile", "settings": { "caption": "Landscape lighting", "shape": "square" } },
        { "type": "tile", "settings": { "caption": "Warehouse fit-out", "shape": "landscape" } },
        { "type": "tile", "settings": { "caption": "Smart-home wiring", "shape": "portrait" } },
        { "type": "tile", "settings": { "caption": "Generator transfer switch", "shape": "square" } }
      ]
    }
  ]
}
{% endschema %}
