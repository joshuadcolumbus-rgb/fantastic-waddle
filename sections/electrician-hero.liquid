{%- comment -%}
  Hero: gradient-clipped headline over the ambient light field, with a
  glass lead-capture panel. Inputs rest on a 1px rgba(255,255,255,0.08)
  hairline and bloom into the pulsing amber halo on focus (see
  .volt-field-input in assets/base.css).
{%- endcomment -%}

<section class="volt-section eh-hero">
  <div class="volt-section__inner eh-hero__grid">
    <div class="eh-hero__copy" data-volt-reveal>
      <p class="volt-kicker">{{ section.settings.kicker | escape }}</p>
      <h1 class="volt-title">{{ section.settings.heading | escape }}</h1>
      <p class="volt-lede">{{ section.settings.subheading | escape }}</p>

      <div class="eh-hero__actions">
        {%- if section.settings.cta_label != blank -%}
          <a class="volt-btn volt-btn--primary" href="{{ section.settings.cta_link | default: '#quote' }}">
            {{ section.settings.cta_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="volt-btn volt-btn--ghost" href="{{ section.settings.secondary_link | default: '#services' }}">
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <dl class="eh-hero__stats">
        {%- for block in section.blocks -%}
          <div class="eh-hero__stat" {{ block.shopify_attributes }}>
            <dt>{{ block.settings.value | escape }}</dt>
            <dd>{{ block.settings.label | escape }}</dd>
          </div>
        {%- endfor -%}
      </dl>
    </div>

    <div id="quote" class="volt-panel eh-hero__form" data-volt-reveal style="--volt-stagger: 2;">
      <h3 class="volt-title">{{ section.settings.form_heading | escape }}</h3>
      <p class="eh-hero__form-note">{{ section.settings.form_note | escape }}</p>

      {%- form 'contact', class: 'eh-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="eh-form__success" role="status">{{ 'sections.hero.form_success' | t }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="eh-form__error" role="alert">{{ form.errors | default_errors }}</p>
        {%- endif -%}

        <label class="eh-form__label" for="EhFormName">{{ 'sections.hero.form_name' | t }}</label>
        <input
          class="volt-field-input"
          id="EhFormName"
          type="text"
          name="contact[name]"
          autocomplete="name"
          placeholder="{{ 'sections.hero.form_name_placeholder' | t }}"
        >

        <label class="eh-form__label" for="EhFormEmail">{{ 'sections.hero.form_email' | t }}</label>
        <input
          class="volt-field-input"
          id="EhFormEmail"
          type="email"
          name="contact[email]"
          autocomplete="email"
          required
          placeholder="{{ 'sections.hero.form_email_placeholder' | t }}"
        >

        <label class="eh-form__label" for="EhFormBody">{{ 'sections.hero.form_message' | t }}</label>
        <textarea
          class="volt-field-input"
          id="EhFormBody"
          name="contact[body]"
          rows="3"
          placeholder="{{ 'sections.hero.form_message_placeholder' | t }}"
        ></textarea>

        <button class="volt-btn volt-btn--primary eh-form__submit" type="submit">
          {{ 'sections.hero.form_submit' | t }}
        </button>
      {%- endform -%}
    </div>
  </div>
</section>

{% style %}
  .eh-hero { padding-top: clamp(4.5rem, 12vw, 8.5rem); }

  .eh-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
  }

  @media (min-width: 980px) {
    .eh-hero__grid { grid-template-columns: 1.25fr 0.85fr; }
  }

  .eh-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.2rem;
  }

  .eh-hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin: 3rem 0 0;
  }

  .eh-hero__stat dt {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--volt-amber);
  }

  .eh-hero__stat dd {
    margin: 0.2rem 0 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--volt-ink-dim);
  }

  .eh-hero__form { padding: clamp(1.6rem, 3vw, 2.4rem); }

  .eh-hero__form-note {
    margin: -0.3rem 0 1.4rem;
    font-size: 0.9rem;
    color: var(--volt-ink-dim);
  }

  .eh-form { display: flex; flex-direction: column; gap: 0.55rem; }

  .eh-form__label {
    margin-top: 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--volt-ink-dim);
  }

  .eh-form__submit { margin-top: 1.1rem; width: 100%; }

  .eh-form__success { color: #4ade80; font-size: 0.9rem; }
  .eh-form__error { color: #f87171; font-size: 0.9rem; }
{% endstyle %}

{% schema %}
{
  "name": "Electrician hero",
  "class": "section-electrician-hero",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Licensed &middot; Bonded &middot; 24/7 Emergency"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Power, engineered to perfection"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Master electricians delivering panel upgrades, EV charging, and whole-home rewiring with industrial-grade precision."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Get a free quote"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore services"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Request service"
    },
    {
      "type": "text",
      "id": "form_note",
      "label": "Form note",
      "default": "Response within one business hour."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "25+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Years in service"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Electrician hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "25+", "label": "Years in service" } },
        { "type": "stat", "settings": { "value": "4.9", "label": "Average rating" } },
        { "type": "stat", "settings": { "value": "12k", "label": "Jobs completed" } }
      ]
    }
  ]
}
{% endschema %}
