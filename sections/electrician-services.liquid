{%- comment -%}
  ASYMMETRIC GRID BREAKOUT — services.

  A 6-track dense CSS grid with explicit span math per block emphasis:
    feature  → grid-column: span 4; grid-row: span 2;  (hero-tier work)
    wide     → grid-column: span 3;                    (editorial breakers)
    tall     → grid-column: span 2; grid-row: span 2;  (vertical accents)
    standard → grid-column: span 2;                    (baseline cells)
  grid-auto-flow: dense backfills the gaps, producing the staggered
  masonry rhythm instead of uniform rows.
{%- endcomment -%}

<section id="services" class="volt-section eh-services">
  <div class="volt-section__inner">
    <header class="eh-services__head" data-volt-reveal>
      <p class="volt-kicker">{{ section.settings.kicker | escape }}</p>
      <h2 class="volt-title">{{ section.settings.heading | escape }}</h2>
      <p class="volt-lede">{{ section.settings.subheading | escape }}</p>
    </header>

    <div class="eh-services__grid">
      {%- for block in section.blocks -%}
        <article
          class="volt-panel eh-service eh-service--{{ block.settings.emphasis }}"
          data-volt-reveal
          style="--volt-stagger: {{ forloop.index0 | modulo: 4 }};"
          {{ block.shopify_attributes }}
        >
          <span class="eh-service__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          <h3>{{ block.settings.title | escape }}</h3>
          <p class="eh-service__desc">{{ block.settings.description | escape }}</p>
          {%- if block.settings.tag != blank -%}
            <span class="eh-service__tag">{{ block.settings.tag | escape }}</span>
          {%- endif -%}
          {%- if block.settings.link != blank -%}
            <a class="eh-service__link" href="{{ block.settings.link }}">
              {{ 'sections.services.learn_more' | t }} &rarr;
            </a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% style %}
  .eh-services__head { max-width: 640px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }

  .eh-services__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(150px, auto);
    grid-auto-flow: dense;
    gap: clamp(0.9rem, 2vw, 1.4rem);
  }

  .eh-service {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: clamp(1.3rem, 2.5vw, 1.9rem);
    grid-column: span 2;
  }

  .eh-service--wide { grid-column: span 3; }

  .eh-service--tall {
    grid-column: span 2;
    grid-row: span 2;
    justify-content: flex-end;
  }

  .eh-service--feature {
    grid-column: span 4;
    grid-row: span 2;
    justify-content: flex-end;
    background:
      radial-gradient(60% 80% at 85% 10%, rgba(245, 158, 11, 0.12) 0%, transparent 70%),
      var(--volt-glass);
  }

  .eh-service--feature h3 { font-size: clamp(1.4rem, 2.6vw, 1.9rem); }

  /* Tablet: collapse to 4 tracks, keep the stagger */
  @media (max-width: 979px) {
    .eh-services__grid { grid-template-columns: repeat(4, 1fr); }
    .eh-service--feature { grid-column: span 4; }
    .eh-service--wide { grid-column: span 2; }
  }

  /* Mobile: single column, spans released */
  @media (max-width: 639px) {
    .eh-services__grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
    .eh-service,
    .eh-service--wide,
    .eh-service--tall,
    .eh-service--feature {
      grid-column: auto;
      grid-row: auto;
    }
  }

  .eh-service__icon { font-size: 1.6rem; }

  .eh-service__desc {
    margin: 0;
    font-size: 0.92rem;
    color: var(--volt-ink-dim);
  }

  .eh-service__tag {
    position: absolute;
    top: 1.1rem;
    right: 1.1rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--volt-amber-soft);
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--volt-amber);
  }

  .eh-service__link {
    margin-top: auto;
    padding-top: 0.6rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--volt-amber);
  }
{% endstyle %}

{% schema %}
{
  "name": "Electrician services",
  "class": "section-electrician-services",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Capabilities"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Full-spectrum electrical work"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From service calls to full commercial fit-outs — engineered, inspected, and guaranteed."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or character)",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe the service and its value."
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Corner tag (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "select",
          "id": "emphasis",
          "label": "Grid emphasis",
          "options": [
            { "value": "standard", "label": "Standard (2 columns)" },
            { "value": "wide", "label": "Wide (3 columns)" },
            { "value": "tall", "label": "Tall (2 columns × 2 rows)" },
            { "value": "feature", "label": "Feature (4 columns × 2 rows)" }
          ],
          "default": "standard"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Electrician services",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "🔌",
            "title": "Electrical Panel Upgrades",
            "description": "100A to 200A service upgrades and subpanel installations with load calculation, permit handling, and inspection scheduling.",
            "tag": "HIGH DEMAND",
            "emphasis": "feature"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "🚗",
            "title": "EV Charger Installations",
            "description": "Level 2 home charging infrastructure, sized to your panel capacity and mounted where you actually park.",
            "tag": "FEATURED",
            "emphasis": "wide"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "🛡️",
            "title": "Aluminum Wiring Remediation",
            "description": "Safe corrections for 1970s and 1980s aluminum branch circuits — proper connectors, not quick fixes.",
            "emphasis": "tall"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "🏠",
            "title": "Smart Home Automation",
            "description": "Smart dimmers, switches, and whole-home integration that just works.",
            "emphasis": "standard"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "🧰",
            "title": "Troubleshooting & Faulty Wiring Repairs",
            "description": "Dead outlets, tripping breakers, flickering lights — diagnosed and repaired at the source.",
            "emphasis": "standard"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "💡",
            "title": "Lighting Design & Installations",
            "description": "Recessed lighting, outdoor fixtures, and landscape ambiance designed around how you live.",
            "emphasis": "wide"
          }
        }
