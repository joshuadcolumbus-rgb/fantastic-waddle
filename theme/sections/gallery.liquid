{%- comment -%}
  Portfolio as a pinned passage, not a grid: the section pins, floating
  panels drift through at staggered depths over the twilight scene, and
  each panel FLIP-expands into an accessible fullscreen viewer.
{%- endcomment -%}
<section
  class="ts-section ts-gallery"
  data-gallery
  {% render 'scene-anchor', beat: section.settings.beat, type: 'gallery' %}
>
  <div class="ts-gallery__pin">
    <div class="ts-container ts-gallery__head">
      {% render 'section-heading',
        eyebrow: section.settings.eyebrow,
        title: section.settings.title,
        lede: section.settings.lede
      %}
    </div>

    <div class="ts-gallery__track">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Portfolio journey",
  "tag": "div",
  "blocks": [{ "type": "gallery-image" }],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Selected work"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Grounds we have composed"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Lede",
      "default": "A walk through recent commissions — keep scrolling to drift through the collection."
    },
    {
      "type": "select",
      "id": "beat",
      "label": "Scene mood",
      "info": "Where this chapter sits in the dawn-to-night journey behind the content.",
      "options": [
        { "value": "dawn-garden", "label": "Dawn garden" },
        { "value": "morning-meadow", "label": "Morning meadow" },
        { "value": "stone-path", "label": "Stone path" },
        { "value": "pergola-court", "label": "Pergola court" },
        { "value": "water-garden", "label": "Water garden" },
        { "value": "emerald-lawn", "label": "Emerald lawn" },
        { "value": "dusk-glow", "label": "Dusk glow" },
        { "value": "stone-twilight", "label": "Stone twilight" },
        { "value": "estate-blue", "label": "Estate blue hour" },
        { "value": "twilight-gallery", "label": "Twilight gallery" },
        { "value": "firefly-night", "label": "Firefly night" },
        { "value": "moonlit-path", "label": "Moonlit path" },
        { "value": "lantern-walk", "label": "Lantern walk" },
        { "value": "still-water", "label": "Still water night" }
      ],
      "default": "twilight-gallery"
    }
  ],
  "presets": [
    {
      "name": "Portfolio journey",
      "blocks": [
        { "type": "gallery-image", "settings": { "title": "Hillcrest Estate", "meta": "Private garden · 2.4 acres", "depth": "0.4" } },
        { "type": "gallery-image", "settings": { "title": "Stillwater Court", "meta": "Courtyard & pond", "depth": "-0.3" } },
        { "type": "gallery-image", "settings": { "title": "The Olive Walk", "meta": "Entry sequence", "depth": "0.2" } },
        { "type": "gallery-image", "settings": { "title": "Lantern Terrace", "meta": "Outdoor room & fire", "depth": "-0.4" } },
        { "type": "gallery-image", "settings": { "title": "Meadow House", "meta": "Naturalistic meadow", "depth": "0.3" } }
      ]
    }
  ]
}
{% endschema %}
