<header class="ts-header" role="banner">
  <div class="ts-header__inner">
    <a class="ts-header__brand" href="{{ routes.root_url }}">
      {%- if settings.logo != blank -%}
        {{ settings.logo | image_url: width: 240 | image_tag: alt: shop.name, loading: 'eager' }}
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <nav class="ts-header__nav" aria-label="Primary">
      {%- for link in section.settings.menu.links -%}
        <a class="ts-header__link" href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    {%- if section.settings.cta_label != blank -%}
      <div class="ts-header__cta">
        {% render 'button', label: section.settings.cta_label, url: section.settings.cta_link, style: 'ghost' %}
      </div>
    {%- endif -%}

    <button class="ts-header__toggle" type="button" aria-expanded="false" aria-controls="ts-nav-drawer" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="ts-nav-drawer" id="ts-nav-drawer">
  {%- for link in section.settings.menu.links -%}
    <a class="ts-nav-drawer__link" href="{{ link.url }}">{{ link.title }}</a>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Header",
  "class": "shopify-section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Book a consultation"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ]
}
{% endschema %}
