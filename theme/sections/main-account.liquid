<section class="ts-section ts-commerce">
  <div class="ts-container">
    <h1 class="ts-chapter__title" data-reveal="chars">{{ 'customer.account.title' | t }}</h1>
    <p>
      <a href="{{ routes.account_addresses_url }}">{{ 'customer.account.view_addresses' | t }}</a> ·
      <a href="{{ routes.account_logout_url }}">{{ 'customer.account.log_out' | t }}</a>
    </p>

    <h2 style="font-size: var(--fs-h3); margin-top: var(--space-4);">{{ 'customer.account.orders' | t }}</h2>
    {%- paginate customer.orders by 20 -%}
      {%- if customer.orders.size > 0 -%}
        <table class="ts-table">
          <thead>
            <tr>
              <th scope="col">Order</th>
              <th scope="col">Date</th>
              <th scope="col">Payment</th>
              <th scope="col">Fulfillment</th>
              <th scope="col">Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
                <td>{{ order.financial_status_label }}</td>
                <td>{{ order.fulfillment_status_label }}</td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      {%- else -%}
        <p class="ts-lede">No orders yet.</p>
      {%- endif -%}
      {%- if paginate.pages > 1 -%}
        <nav style="margin-top: var(--space-3);" aria-label="Pagination">{{ paginate | default_pagination }}</nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Account",
  "settings": []
}
{% endschema %}
