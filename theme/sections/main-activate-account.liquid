<section class="ts-section ts-commerce">
  <div class="ts-container" style="max-width: 30rem;">
    <h1 class="ts-chapter__title" data-reveal="chars">{{ 'customer.activate_account.title' | t }}</h1>

    {% form 'activate_customer_password', class: 'ts-form' %}
      {%- if form.errors -%}
        <p role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="ts-field">
        <label for="activate-password">{{ 'customer.activate_account.password' | t }}</label>
        <input type="password" id="activate-password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <div class="ts-field">
        <label for="activate-password-confirm">{{ 'customer.activate_account.password_confirm' | t }}</label>
        <input type="password" id="activate-password-confirm" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>
      <div style="display: flex; gap: var(--space-2);">
        <button type="submit" class="ts-btn" data-magnetic>
          <span class="ts-btn__label">{{ 'customer.activate_account.submit' | t }}</span>
        </button>
        <button type="submit" class="ts-btn ts-btn--ghost" name="decline">
          <span class="ts-btn__label">{{ 'customer.activate_account.decline' | t }}</span>
        </button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Activate account",
  "settings": []
}
{% endschema %}
