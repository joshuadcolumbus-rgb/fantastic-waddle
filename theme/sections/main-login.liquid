<section class="ts-section ts-commerce">
  <div class="ts-container" style="max-width: 30rem;">
    <h1 class="ts-chapter__title" data-reveal="chars">{{ 'customer.login.title' | t }}</h1>

    {% form 'customer_login', class: 'ts-form' %}
      {%- if form.errors -%}
        <p role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="ts-field">
        <label for="login-email">{{ 'customer.login.email' | t }}</label>
        <input type="email" id="login-email" name="customer[email]" autocomplete="email" required>
      </div>
      <div class="ts-field">
        <label for="login-password">{{ 'customer.login.password' | t }}</label>
        <input type="password" id="login-password" name="customer[password]" autocomplete="current-password" required>
      </div>
      <button type="submit" class="ts-btn" data-magnetic>
        <span class="ts-btn__label">{{ 'customer.login.sign_in' | t }}</span>
      </button>
      <p>
        <a href="#recover">{{ 'customer.login.forgot_password' | t }}</a> ·
        <a href="{{ routes.account_register_url }}">{{ 'customer.login.create_account' | t }}</a>
      </p>
    {% endform %}

    <div id="recover" style="margin-top: var(--space-4);">
      <h2 style="font-size: var(--fs-h3);">{{ 'customer.recover_password.title' | t }}</h2>
      <p class="ts-lede" style="font-size: 1rem;">{{ 'customer.recover_password.subtext' | t }}</p>
      {% form 'recover_customer_password', class: 'ts-form' %}
        {%- if form.errors -%}
          <p role="alert">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="ts-field">
          <label for="recover-email">{{ 'customer.login.email' | t }}</label>
          <input type="email" id="recover-email" name="email" autocomplete="email" required>
        </div>
        <button type="submit" class="ts-btn ts-btn--ghost">
          <span class="ts-btn__label">{{ 'customer.recover_password.submit' | t }}</span>
        </button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Login",
  "settings": []
}
{% endschema %}
