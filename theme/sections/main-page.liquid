<section class="ts-section ts-commerce">
  <div class="ts-container">
    <p class="ts-eyebrow">{{ shop.name }}</p>
    <h1 class="ts-chapter__title" data-reveal="chars">{{ page.title }}</h1>
    <div class="ts-glass" style="padding: clamp(1.6rem, 3.5vw, 3rem); margin-top: var(--space-3); max-width: 52em;">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
