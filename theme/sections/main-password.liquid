<section class="ts-section ts-commerce" style="display: grid; align-content: center; text-align: center; min-height: 80svh;">
  <div class="ts-container" style="max-width: 30rem;">
    <p class="ts-eyebrow" style="justify-content: center;">{{ shop.name }}</p>
    <h1 class="ts-chapter__title" style="margin-inline: auto;">{{ 'general.password_page.opening_soon' | t }}</h1>

    {% form 'storefront_password', class: 'ts-form' %}
      {%- if form.errors -%}
        <p role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="ts-field" style="text-align: left;">
        <label for="password-input">{{ 'general.password_page.login_form_password_label' | t }}</label>
        <input type="password" id="password-input" name="password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="ts-btn" data-magnetic>
        <span class="ts-btn__label">{{ 'general.password_page.login_form_submit' | t }}</span>
      </button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
