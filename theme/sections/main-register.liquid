<section class="ts-section ts-commerce">
  <div class="ts-container" style="max-width: 30rem;">
    <h1 class="ts-chapter__title" data-reveal="chars">{{ 'customer.register.title' | t }}</h1>

    {% form 'create_customer', class: 'ts-form' %}
      {%- if form.errors -%}
        <p role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="ts-field">
        <label for="reg-first">{{ 'customer.register.first_name' | t }}</label>
        <input type="text" id="reg-first" name="customer[first_name]" autocomplete="given-name">
      </div>
      <div class="ts-field">
        <label for="reg-last">{{ 'customer.register.last_name' | t }}</label>
        <input type="text" id="reg-last" name="customer[last_name]" autocomplete="family-name">
      </div>
      <div class="ts-field">
        <label for="reg-email">{{ 'customer.register.email' | t }}</label>
        <input type="email" id="reg-email" name="customer[email]" autocomplete="email" required>
      </div>
      <div class="ts-field">
        <label for="reg-password">{{ 'customer.register.password' | t }}</label>
        <input type="password" id="reg-password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <button type="submit" class="ts-btn" data-magnetic>
        <span class="ts-btn__label">{{ 'customer.register.submit' | t }}</span>
      </button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Register",
  "settings": []
}
{% endschema %}
