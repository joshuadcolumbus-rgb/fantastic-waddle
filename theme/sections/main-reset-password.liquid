<section class="ts-section ts-commerce">
  <div class="ts-container" style="max-width: 30rem;">
    <h1 class="ts-chapter__title" data-reveal="chars">{{ 'customer.reset_password.title' | t }}</h1>

    {% form 'reset_customer_password', class: 'ts-form' %}
      {%- if form.errors -%}
        <p role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="ts-field">
        <label for="reset-password">{{ 'customer.reset_password.password' | t }}</label>
        <input type="password" id="reset-password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <div class="ts-field">
        <label for="reset-password-confirm">{{ 'customer.reset_password.password_confirm' | t }}</label>
        <input type="password" id="reset-password-confirm" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>
      <button type="submit" class="ts-btn" data-magnetic>
        <span class="ts-btn__label">{{ 'customer.reset_password.submit' | t }}</span>
      </button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "settings": []
}
{% endschema %}
