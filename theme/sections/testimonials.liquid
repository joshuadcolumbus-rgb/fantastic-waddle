<section
  class="ts-section ts-testimonials"
  {% render 'scene-anchor', beat: section.settings.beat, type: 'testimonials' %}
>
  <div class="ts-container">
    {% render 'section-heading',
      eyebrow: section.settings.eyebrow,
      title: section.settings.title,
      lede: section.settings.lede
    %}

    <div class="ts-testimonials__rail" data-stagger>
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "div",
  "blocks": [{ "type": "testimonial" }],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "In their words"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Clients who walk their gardens nightly"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Lede"
    },
    {
      "type": "select",
      "id": "beat",
      "label": "Scene mood",
      "info": "Where this chapter sits in the dawn-to-night journey behind the content.",
      "options": [
        { "value": "dawn-garden", "label": "Dawn garden" },
        { "value": "morning-meadow", "label": "Morning meadow" },
        { "value": "stone-path", "label": "Stone path" },
        { "value": "pergola-court", "label": "Pergola court" },
        { "value": "water-garden", "label": "Water garden" },
        { "value": "emerald-lawn", "label": "Emerald lawn" },
        { "value": "dusk-glow", "label": "Dusk glow" },
        { "value": "stone-twilight", "label": "Stone twilight" },
        { "value": "estate-blue", "label": "Estate blue hour" },
        { "value": "twilight-gallery", "label": "Twilight gallery" },
        { "value": "firefly-night", "label": "Firefly night" },
        { "value": "moonlit-path", "label": "Moonlit path" },
        { "value": "lantern-walk", "label": "Lantern walk" },
        { "value": "still-water", "label": "Still water night" }
      ],
      "default": "firefly-night"
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "They didn't plant a garden — they composed one. Every window of the house now frames a picture.", "name": "E. & M. Hartwell", "meta": "Hillcrest Estate" } },
        { "type": "testimonial", "settings": { "quote": "The lighting alone changed how we live. We spend every evening outside now, well past dark.", "name": "D. Okafor", "meta": "Lantern Terrace" } },
        { "type": "testimonial", "settings": { "quote": "Flawless process — one team from first sketch to final stone. The craftsmanship is remarkable.", "name": "S. Lindqvist", "meta": "Stillwater Court" } }
      ]
    }
  ]
}
{% endschema %}
